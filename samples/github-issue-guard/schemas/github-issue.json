{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GitHub Issue Extraction",
  "description": "Structured extraction from a GitHub issue for the Dual LLM pattern",
  "type": "object",
  "required": ["title", "requirements", "state"],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 200,
      "description": "Issue title in plain text"
    },
    "requirements": {
      "type": "array",
      "description": "Requirements or tasks extracted from the issue body",
      "items": {
        "type": "object",
        "required": ["id", "text", "priority"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^REQ_[0-9]+$"
          },
          "text": {
            "type": "string",
            "maxLength": 500
          },
          "priority": {
            "enum": ["high", "medium", "low"]
          }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "description": "Acceptance criteria extracted from the issue body",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AC_[0-9]+$"
          },
          "description": {
            "type": "string",
            "maxLength": 500
          }
        }
      }
    },
    "state": {
      "type": "string",
      "enum": ["open", "closed"],
      "description": "Issue state"
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 50
      },
      "description": "Issue labels"
    },
    "assignee": {
      "type": "string",
      "maxLength": 100,
      "description": "Assigned user"
    },
    "milestone": {
      "type": "string",
      "maxLength": 100,
      "description": "Milestone name"
    }
  }
}
