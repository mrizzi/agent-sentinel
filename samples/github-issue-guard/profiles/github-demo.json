{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "samples/github-issue-guard/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__github__(issue_read|list_issues|search_issues)",
        "hooks": [
          {
            "type": "command",
            "command": "samples/github-issue-guard/hooks/post-tool-use.sh",
            "statusMessage": "Quarantining MCP response..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__github__(issue_write|add_issue_comment)",
        "hooks": [
          {
            "type": "command",
            "command": "samples/github-issue-guard/hooks/pre-tool-use.sh",
            "statusMessage": "Dereferencing symbolic variables..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "samples/github-issue-guard/hooks/session-end.sh"
          }
        ]
      }
    ]
  }
}
